# =============================================================================
# FutureAGI Core Frontend - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# Backend API URL
VITE_HOST_API=http://localhost:8000

# Frontend assets URL
VITE_ASSETS_API=http://localhost:3031

# Environment: dev | production
VITE_ENVIRONMENT=dev

# Mixpanel analytics token
VITE_MIXPANEL_TOKEN=your-mixpanel-token

# Help/support link
VITE_HELP_LINK=https://meetings.hubspot.com/your-org/help

# Generate link (usually same as frontend URL)
VITE_GENERATE_LINK=http://localhost:3031

# Google reCAPTCHA site key
VITE_GOOGLE_SITE_KEY=your-recaptcha-site-key

# AG Grid Enterprise license key (optional)
# VITE_AG_GRID_LICENSE_KEY=your-ag-grid-license-key

# Stripe public key
VITE_STRIPE_PUBLIC_KEY=pk_test_...

# Pendo analytics key (optional)
# VITE_PENDO_API_KEY=your-pendo-key

# Google Ads conversion tracking
# Both flag AND ID must be set for tracking to fire. Leave ENABLED=false in dev
# or staging so test signups don't pollute production Ads reporting.
# SIGNUP_LABEL reuses the landing-page "Sign-up click" conversion label so
# both clicks and completions count toward the same Ads conversion action.
# The app-side completion fire prefixes transaction_id with "signup_completed_"
# to keep the two distinguishable in Ads logs / audits.
VITE_GOOGLE_ADS_ENABLED=false
VITE_GOOGLE_ADS_ID=AW-XXXXXXXXXXX
VITE_GOOGLE_ADS_SIGNUP_LABEL=conversion-label-from-google-ads
VITE_GA_ID=G-XXXXXXXXXX

VITE_REDDIT_ADS_ENABLED=false
VITE_REDDIT_PIXEL_ID=a2_XXXXXXXXXXXX

VITE_TWITTER_ADS_ENABLED=false
VITE_TWITTER_PIXEL_ID=XXXXX

VITE_AD_CONVERSION_VALUE=75.0
VITE_AD_CONVERSION_CURRENCY=USD

# Disable ESLint errors in dev overlay
ESLINT_NO_DEV_ERRORS=true
