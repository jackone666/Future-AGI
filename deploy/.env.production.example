# Production environment for self-hosted Future AGI.
# Copy to deploy/.env.production and fill in. Then:
#
#   docker compose --env-file deploy/.env.production \
#     -f docker-compose.yml -f deploy/docker-compose.production.yml up -d
#
# The production overlay refuses to boot if any REQUIRED value is empty.

# ---- REQUIRED — generate with: openssl rand -hex 32 ----
SECRET_KEY=
AGENTCC_INTERNAL_API_KEY=
AGENTCC_ADMIN_TOKEN=

# ---- REQUIRED — DB / storage credentials ----
PG_PASSWORD=
MINIO_ROOT_PASSWORD=

# ---- REQUIRED — pin a specific release per image ----
# Each service has an independent version. Don't run `:latest` in prod.
FUTURE_AGI_VERSION=v1.22.43
FRONTEND_VERSION=v1.0.0
AGENTCC_GATEWAY_VERSION=v0.1.0
SERVING_VERSION=v1.0.0
CODE_EXECUTOR_VERSION=v1.0.0

# ---- REQUIRED — public URLs ----
# FRONTEND_URL drives backend's email/OAuth links.
# VITE_HOST_API is the URL the browser uses to reach backend.
FRONTEND_URL=https://app.your-domain.com
VITE_HOST_API=https://api.your-domain.com

# ---- REQUIRED — RabbitMQ credentials (don't ship `password` to prod) ----
RABBITMQ_USER=futureagi
RABBITMQ_PASSWORD=

# ---- Optional — full list in ../.env.example ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
