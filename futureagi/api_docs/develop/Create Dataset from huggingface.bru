meta {
  name: Create Dataset from huggingface
  type: http
  seq: 2
}

post {
  url: {{host}}/model-hub/develops/create-dataset-from-huggingface/
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:multipart-form {
  model_type: GenerativeLLM
  new_dataset_name: test_0100
  huggingface_dataset_name: dair-ai/emotion
  huggingface_dataset_config: split
  huggingface_dataset_split: test
  num rows: 100
}
