meta {
  name: secrets
  type: http
  seq: 25
}

get {
  url: {{host}}/model-hub/secrets/
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
      "name": "My API Key",
      "description": "API key for service X",
      "secret_type": "API_KEY",
      "key": "your-secret-key-here"
  }
}
