meta {
  name: Create Dataset by file
  type: http
  seq: 1
}

post {
  url: {{host}}/model-hub/develops/create-dataset-from-local-file/
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:multipart-form {
  model_type: GenerativeLLM
  file: @file(/Users/vineeth/Downloads/test-develop-types.csv)
  new_dataset_name: ds_0321
}
