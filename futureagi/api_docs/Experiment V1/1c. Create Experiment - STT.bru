    "name": "Run Exp 2",
    "prompt_config": [
      {
        "name": "rp1",
        "version": "",
        "model_type": "stt",
        "messages": [
          {
            "role": "system",
            "content": [{"type": "text", "text": ""}]
          },
          {
            "role": "user",
            "content": [{"type": "text", "text": "{{b9341955-3fc7-4901-9622-5db496ecfe58}}"}]
          }
        ],
        "model": ["elevenlabs/scribe_v1"],
        "voice_input_column": "b9341955-3fc7-4901-9622-5db496ecfe58",
        "model_params": {
