meta {
  name: Restore Agent Version
  type: http
  seq: 7
}

post {
  url: http://localhost:8000/simulate/agent-definitions/{{agent_id}}/versions/{{version_id}}/restore/
  body: none
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

