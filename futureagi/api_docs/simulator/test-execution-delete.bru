meta {
  name: Delete Test Execution
  type: http
  seq: 15
}

delete {
  url: http://localhost:8000/simulate/test-executions/test-exec-1/delete/
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

docs {
  name: Delete Test Execution
  description: Delete a specific test execution and all its associated call executions
  request: {
    "method": "DELETE",
    "url": "http://localhost:8000/simulate/test-executions/{test_execution_id}/delete/",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    }
  }
  response: {
    "message": "Test execution deleted successfully."
  }
  error_responses: [
    {
      "status": 400,
      "error": "Cannot delete a test execution that is currently running."
    },
    {
      "status": 404,
      "error": "Organization not found for the user."
    },
    {
      "status": 404,
      "error": "Test execution not found."
    },
    {
      "status": 500,
      "error": "Failed to delete test execution: {error_message}"
    }
  ]
  notes: [
    "This endpoint will delete the test execution and all its associated call executions",
    "Cannot delete test executions that are currently running",
    "Requires authentication and organization access",
    "Returns a success message on successful deletion"
  ]
}
