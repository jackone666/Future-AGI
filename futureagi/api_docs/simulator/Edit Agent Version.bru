meta {
  name: Edit Agent Version
  type: http
  seq: 4
}

put {
  url: http://localhost:8000/simulate/agent-definitions/{{agent_id}}/versions/{{version_id}}/edit/
  body: json
  auth: bearer
}

body:json {
