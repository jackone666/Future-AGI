meta {
  name: Delete Agent Version
  type: http
  seq: 6
}

delete {
  url: http://localhost:8000/simulate/agent-definitions/{{agent_id}}/versions/{{version_id}}/delete/
  body: none
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

docs {
  name: Delete Agent Version
  description: Soft delete an agent version (marks as deleted but preserves data)
  response: {
    "message": "Agent version deleted successfully"
  }
  error_response: {
    "error": "Cannot delete the only active version. Please activate another version first."
  }
}
