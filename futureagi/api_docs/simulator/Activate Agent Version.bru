meta {
  name: Activate Agent Version
  type: http
  seq: 8
}

post {
  url: http://localhost:8000/simulate/agent-definitions/{{agent_id}}/versions/{{version_id}}/activate/
  body: none
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

