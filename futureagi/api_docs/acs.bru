meta {
  name: acs
  type: http
  seq: 8
}

get {
  url: http://localhost:8000/saml2_auth/idp-upload/
  body: none
  auth: bearer
}

headers {
  Authorization: Bearer {{access_token}}
  Content-Type: application/json
  Cookie: {{xsrf_cookie}}
  ~Location: http://localhost:8000
}

auth:bearer {
  token: {{access_token}}
}
