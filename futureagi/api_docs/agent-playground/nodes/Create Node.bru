meta {
  name: Create Node
  type: http
  seq: 1
}

post {
  url: {{host}}/agent-playground/graphs/:graph_id/versions/:version_id/nodes/
  body: json
  auth: bearer
}

params:path {
  graph_id: {{graph_id}}
  version_id: {{version_id}}
}

auth:bearer {
  token: {{access_token}}
}

