meta {
  name: List Graphs
  type: http
  seq: 1
}

get {
  url: {{host}}/agent-playground/graphs/?page_number=1&page_size=10
  body: none
  auth: bearer
}

params:query {
  page_number: 4
  page_size: 10
  ~search: Multi Agent
  ~is_template: true
  ~pinned_ids: 02b3c7e5-0d2c-4cf5-9bf2-79709608123a
}

auth:bearer {
  token: {{access_token}}
}

docs {
  # List Graphs

  List all graphs for the user's organization/workspace.

  ## Query Parameters
  - `is_template` (optional): Filter by template status (true/false)

  ## Response
  Returns array of graphs with lightweight version info (no nodes/edges):
  ```json
  {
    "status": true,
    "result": [
      {
        "id": "graph-uuid",
        "name": "My Pipeline",
        "description": "A pipeline for processing data",
        "is_template": false,
        "created_at": "2024-01-15T10:30:00Z",
        "updated_at": "2024-01-15T10:30:00Z",
        "created_by": {
          "id": "user-uuid",
          "name": "John Doe",
          "email": "john@example.com"
        },
        "collaborators": [],
        "current_version": {
          "id": "version-uuid",
          "version_number": 2,
          "status": "active",
          "tags": [],
          "commit_message": "Added summarization step",
          "created_at": "2024-01-15T10:30:00Z"
        }
      }
    ]
  }
  ```

  ## Notes
  - `current_version` returns the active version if one exists, otherwise the latest draft
  - No nodes/edges are included in the list response for performance
}
