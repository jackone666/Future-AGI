meta {
  name: Create Graph Version
  type: http
  seq: 8
}

post {
  url: {{host}}/agent-playground/graphs/:graph_id/versions/
  body: json
  auth: bearer
}

params:path {
  graph_id: {{graph_id}}
}

auth:bearer {
  token: {{access_token}}
}

