meta {
  name: 13 - Nonexistent Version ID (Error)
  type: http
  seq: 13
}

post {
  url: {{host}}/model-hub/prompt-labels/assign-multiple-labels/
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "template_version_id": "00000000-0000-0000-0000-000000000000",
    "label_ids": ["{{prod_label_id}}"]
  }
}

docs {
  # Nonexistent Version ID - Error Case

  ## Test Scenario
  Send valid UUID that doesn't exist in database.

  ## Expected Behavior
  - Status: 400 Bad Request
  - Error message about version not found

  ## Expected Response
  ```json
  {
    "status": false,
    "result": "Error assigning multiple labels: Template version does not exist"
  }
  ```

  ## Test Coverage
  - Database lookup validation
  - Not found error handling
}
