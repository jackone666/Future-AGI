meta {
  name: 14 - Nonexistent Label ID (Error)
  type: http
  seq: 14
}

post {
  url: {{host}}/model-hub/prompt-labels/assign-multiple-labels/
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "template_version_id": "{{version_v1_id}}",
    "label_ids": ["00000000-0000-0000-0000-000000000000"]
  }
}

docs {
  # Nonexistent Label ID - Error Case

  ## Test Scenario
  Send valid UUID for label that doesn't exist.

  ## Expected Behavior
  - Status: 400 Bad Request
  - Error message about label not found

  ## Expected Response
  ```json
  {
    "status": false,
    "result": "Error assigning multiple labels: Some labels not found or are not allowed to be assigned"
  }
  ```

  ## Test Coverage
  - Label validation
  - Not found error handling
}
