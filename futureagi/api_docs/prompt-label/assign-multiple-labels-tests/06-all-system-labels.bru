meta {
  name: 06 - Assign All System Labels (Success)
  type: http
  seq: 6
}

post {
  url: {{host}}/model-hub/prompt-labels/assign-multiple-labels/
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "template_version_id": "{{version_v2_id}}",
    "label_ids": [
      "{{prod_label_id}}",
      "{{staging_label_id}}",
      "{{dev_label_id}}"
    ]
  }
}

docs {
  # Assign All System Labels - Success Case

  ## Test Scenario
  Assigns all three system labels (Production, Staging, Development) at once.

  ## Prerequisites
  - All three system labels exist
  - `version_v1` has all three labels

  ## Expected Behavior
  - Status: 200 OK
  - All three system labels are added to version_v2

  ## Expected Response
  ```json
  {
    "status": true,
    "result": "Labels assigned successfully"
  }
  ```

  ## Test Coverage
  - Maximum system labels
  - Bulk assignment
}
