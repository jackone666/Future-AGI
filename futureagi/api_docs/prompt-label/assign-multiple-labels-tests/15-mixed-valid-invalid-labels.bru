meta {
  name: 15 - Mixed Valid and Invalid Labels (Error)
  type: http
  seq: 15
}

post {
  url: {{host}}/model-hub/prompt-labels/assign-multiple-labels/
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "template_version_id": "{{version_v1_id}}",
    "label_ids": [
      "{{prod_label_id}}",
      "00000000-0000-0000-0000-000000000000"
    ]
  }
}

docs {
  # Mixed Valid and Invalid Labels - Error Case

  ## Test Scenario
  Send mix of valid and invalid label IDs.

  ## Expected Behavior
  - Status: 400 Bad Request
  - Error message about some labels not found
  - Transaction rolled back (no partial assignment)

  ## Expected Response
  ```json
  {
    "status": false,
    "result": "Error assigning multiple labels: Some labels not found or are not allowed to be assigned"
  }
  ```

  ## Test Coverage
  - Partial validation
  - All-or-nothing behavior
  - Transaction rollback
}
