meta {
  name: 19 - Cross Organization Version (Error)
  type: http
  seq: 19
}

post {
  url: {{host}}/model-hub/prompt-labels/assign-multiple-labels/
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "template_version_id": "{{other_org_version_id}}",
    "label_ids": ["{{prod_label_id}}"]
  }
}

docs {
  # Cross Organization Version - Error Case

  ## Test Scenario
  Attempt to modify a version from a different organization.

  ## Prerequisites
  - User authenticated in Organization A
  - Version exists in Organization B

  ## Expected Behavior
  - Status: 400 Bad Request
  - Cross-organization access should be denied

  ## Expected Response
  ```json
  {
    "status": false,
    "result": "Error assigning multiple labels: Template version does not exist"
  }
  ```

  ## Test Coverage
  - Organization isolation
  - Security boundary enforcement
  - Version access control
}
