meta {
  name: 07 - Assign Large Number of Labels (Success)
  type: http
  seq: 7
}

post {
  url: {{host}}/model-hub/prompt-labels/assign-multiple-labels/
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "template_version_id": "{{version_v2_id}}",
    "label_ids": [
      "{{label_1_id}}",
      "{{label_2_id}}",
      "{{label_3_id}}",
      "{{label_4_id}}",
      "{{label_5_id}}",
      "{{label_6_id}}",
      "{{label_7_id}}",
      "{{label_8_id}}",
      "{{label_9_id}}",
      "{{label_10_id}}"
    ]
  }
}

docs {
  # Assign Large Number of Labels - Success Case

  ## Test Scenario
  Assigns 10 custom labels at once to test performance and bulk handling.

  ## Prerequisites
  - 10 custom labels exist in the organization
  - `version_v1` has all 10 labels

  ## Expected Behavior
  - Status: 200 OK
  - All 10 labels are added to version_v2
  - Performance should be acceptable

  ## Expected Response
  ```json
  {
    "status": true,
    "result": "Labels assigned successfully"
  }
  ```

  ## Test Coverage
  - Bulk label assignment
  - Performance testing
  - Array handling
}
