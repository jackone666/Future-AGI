meta {
  name: Project ID Missing
  type: http
}

post {
  url: {{host}}/tracer/trace/get_graph_methods/
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "property": "average",
    "interval": "day",
    "filters": [
      {
        "column_id": "created_at",
        "filter_config": {
          "filter_type": "datetime",
          "filter_op": "between",
          "filter_value": [
            "2025-05-20T10:25:59.000Z",
            "2025-06-20T18:29:59.000Z"
          ]
        }
      }
    ],
    "req_data_config": {
      "id": "f7361850-f6cb-4f17-b909-34d513654f5c",
      "output_type": "float",
      "type": "EVAL"
    }
  }
}
