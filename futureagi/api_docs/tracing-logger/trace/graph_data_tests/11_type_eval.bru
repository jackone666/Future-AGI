meta {
  name: Type EVAL
  type: http
  seq: 1
}

post {
  url: {{host}}/tracer/trace/get_graph_methods/
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "project_id": "fd187d9d-8813-4a88-b774-1711d5f3943b",
    "property": "average",
    "interval": "day",
    "filters": [
      {
        "columnId": "created_at",
        "filterConfig": {
          "filterType": "datetime",
          "filterOp": "between",
          "filterValue": [
            "2025-05-20T10:25:59.000Z",
            "2025-06-20T18:29:59.000Z"
          ]
        }
      }
    ],
    "req_data_config": {
      "id": "f7361850-f6cb-4f17-b909-34d513654f5c",
      "output_type": "float",
      "type": "EVAL"
    }
  }
}
